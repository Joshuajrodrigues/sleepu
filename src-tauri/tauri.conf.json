{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sleepu",
  "version": "2.0.0",
  "identifier": "com.joshuarodrigues.sleepu",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title":"Sleepu",
        "width":400,
        "height":500,
        "transparent":true,
        "decorations":false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
